{
  "name": "@pochamp/desktop",
  "version": "0.5.3",
  "private": true,
  "author": "James Lee",
  "type": "module",
  "main": "out/main/index.js",
  "description": "포챔 AI Windows 로컬 도우미",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package:win": "electron-vite build && electron-builder --win nsis --publish never",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@electron-toolkit/utils": "4.0.0",
    "@pochamp/engine": "0.1.0",
    "electron-updater": "^6.8.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "5.0.0",
    "typescript": "7.0.2",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  },
  "build": {
    "appId": "local.pochamp.ai",
    "productName": "포챔 AI",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Pochamp-AI-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://github.com/jinjerry0927/pochamp-ai/releases/latest/download/"
      }
    ]
  }
}
